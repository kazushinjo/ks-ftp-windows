<Window x:Class="KsFtp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:KsFtp.Converters"
        xmlns:vm="clr-namespace:KsFtp.ViewModels"
        xmlns:svc="clr-namespace:KsFtp.Services"
        mc:Ignorable="d"
        Title="KS-FTP" Height="700" Width="1100"
        MinHeight="520" MinWidth="900"
        Background="#F3F3F3"
        FontFamily="Segoe UI Variable,Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:TransferStatusToColorConverter x:Key="StatusToColor"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>

        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background" Value="#EBEBEB"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FileListView" TargetType="ListView">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        </Style>

        <Style x:Key="GridViewColumnHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="#1C1C1C">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="14,16,14,12"
                        BorderBrush="#333333" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="KS-FTP" FontSize="18" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="FTP / FTPS / SFTP" FontSize="10"
                                       Foreground="#888888" Margin="0,1,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="＋" Style="{StaticResource SidebarBtn}"
                                Foreground="White" FontSize="18" Padding="6,2"
                                ToolTip="接続を追加" Click="AddProfile_Click"/>
                    </Grid>
                </Border>

                <!-- Profile list -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ProfilesPanel" Margin="8,8,8,0"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== Main content ===== -->
        <Grid Grid.Column="1">
            <!-- Welcome screen (when not connected) -->
            <Grid x:Name="WelcomePanel"
                  Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
                    <TextBlock Text="🖧" FontSize="64" HorizontalAlignment="Center"
                               FontFamily="Segoe UI Emoji" Margin="0,0,0,16"/>
                    <TextBlock Text="KS-FTP" FontSize="28" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                    <TextBlock Text="左のサイドバーから接続先を選択するか、&#10;新しい接続を追加してください。"
                               FontSize="13" Foreground="#666666" TextAlignment="Center"
                               Margin="0,10,0,24" LineHeight="22"/>
                    <Button Content="接続を追加" Style="{StaticResource PrimaryBtn}"
                            HorizontalAlignment="Center" Click="AddProfile_Click"/>

                    <Border Background="#F0F0F0" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="🌐" FontFamily="Segoe UI Emoji" Margin="0,0,10,0"/>
                                <TextBlock Text="FTP / FTPS / SFTP 対応" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="↔" FontFamily="Segoe UI Emoji" Margin="0,0,10,0"/>
                                <TextBlock Text="左ローカル・右リモートのデュアルペイン" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="📋" FontFamily="Segoe UI Emoji" Margin="0,0,10,0"/>
                                <TextBlock Text="転送キューで進捗管理" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔖" FontFamily="Segoe UI Emoji" Margin="0,0,10,0"/>
                                <TextBlock Text="接続プロファイルの保存・管理" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Connected view -->
            <Grid x:Name="ConnectedPanel"
                  Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="TransferRow" Height="0"/>
                </Grid.RowDefinitions>

                <!-- Dual pane -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Local pane -->
                    <Grid Grid.Column="0" Background="White">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Local header -->
                        <Border Grid.Row="0" Background="#F0F0F0" Padding="10,6"
                                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥" FontFamily="Segoe UI Emoji" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="ローカル" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Local toolbar -->
                        <Border Grid.Row="1" Background="#F8F8F8" Padding="6,4"
                                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <Button Content="⬆" Style="{StaticResource ToolBtn}"
                                            ToolTip="上へ" Click="LocalUp_Click"
                                            IsEnabled="{Binding LocalCanGoUp}"/>
                                    <Button Content="🔄" Style="{StaticResource ToolBtn}"
                                            FontFamily="Segoe UI Emoji"
                                            ToolTip="更新" Click="LocalRefresh_Click"/>
                                </StackPanel>
                                <TextBox x:Name="LocalPathBox" Style="{StaticResource PathBox}"
                                         Text="{Binding LocalCurrentPath, Mode=OneWay}"
                                         Margin="6,0,0,0" IsReadOnly="True"/>
                            </DockPanel>
                        </Border>

                        <!-- Local file list -->
                        <ListView x:Name="LocalListView" Grid.Row="2"
                                  Style="{StaticResource FileListView}"
                                  ItemsSource="{Binding LocalFiles}"
                                  SelectionMode="Extended"
                                  MouseDoubleClick="LocalList_DoubleClick">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <EventSetter Event="PreviewMouseRightButtonDown"
                                                 Handler="ListViewItem_PreviewMouseRightButtonDown"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                                    <GridViewColumn Width="44">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image Width="20" Height="20"
                                                       Source="{Binding ShellIcon}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="名前" Width="220"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="サイズ" Width="80"
                                                    DisplayMemberBinding="{Binding SizeFormatted}"/>
                                    <GridViewColumn Header="更新日時" Width="130"
                                                    DisplayMemberBinding="{Binding ModifiedFormatted}"/>
                                </GridView>
                            </ListView.View>
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="⬆ アップロード" Click="LocalUpload_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📁 フォルダを作成" Click="LocalNewFolder_Click"/>
                                    <Separator/>
                                    <MenuItem Header="🗑 削除" Click="LocalDelete_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                        </ListView>

                        <!-- Local status -->
                        <Border Grid.Row="3" Background="#F5F5F5" Padding="10,4"
                                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                            <TextBlock x:Name="LocalStatusText" FontSize="11"
                                       Foreground="#666666" Text="準備完了"/>
                        </Border>
                    </Grid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="#E0E0E0"/>

                    <!-- Remote pane -->
                    <Grid Grid.Column="2" Background="White">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Remote header -->
                        <Border Grid.Row="0" Background="#F0F0F0" Padding="10,6"
                                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="🖧" FontFamily="Segoe UI Emoji" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="RemoteHeaderText" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#555555" VerticalAlignment="Center"
                                               Text="リモート"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Style="{StaticResource ToolBtn}"
                                            ToolTip="転送キューを表示"
                                            Click="ToggleTransfer_Click">
                                        <Grid Width="24" Height="20">
                                            <TextBlock Text="↕" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border x:Name="BadgeBorder"
                                                    Visibility="{Binding PendingTransferCount, Converter={StaticResource IntToVis}}"
                                                    Background="Red" CornerRadius="6"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Padding="3,0">
                                                <TextBlock x:Name="BadgeText"
                                                           Text="{Binding PendingTransferCount}"
                                                           FontSize="9" Foreground="White"
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Remote toolbar -->
                        <Border Grid.Row="1" Background="#F8F8F8" Padding="6,4"
                                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <Button Content="←" Style="{StaticResource ToolBtn}"
                                            ToolTip="戻る" Click="RemoteBack_Click"
                                            IsEnabled="{Binding CanGoBack}"/>
                                    <Button Content="→" Style="{StaticResource ToolBtn}"
                                            ToolTip="進む" Click="RemoteForward_Click"
                                            IsEnabled="{Binding CanGoForward}"/>
                                    <Button Content="⬆" Style="{StaticResource ToolBtn}"
                                            ToolTip="上へ" Click="RemoteUp_Click"
                                            IsEnabled="{Binding CanGoUp}"/>
                                    <Button Content="🔄" Style="{StaticResource ToolBtn}"
                                            FontFamily="Segoe UI Emoji"
                                            ToolTip="更新" Click="RemoteRefresh_Click"/>
                                </StackPanel>
                                <TextBox x:Name="RemotePathBox" Style="{StaticResource PathBox}"
                                         Text="{Binding CurrentPath, Mode=OneWay}"
                                         Margin="6,0,0,0"
                                         KeyDown="RemotePathBox_KeyDown"/>
                            </DockPanel>
                        </Border>

                        <!-- Loading indicator -->
                        <Border Grid.Row="2" Background="#FAFAFA" Padding="20"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="読み込み中..." FontSize="14" Foreground="#888888"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Remote file list -->
                        <ListView x:Name="RemoteListView" Grid.Row="2"
                                  Style="{StaticResource FileListView}"
                                  ItemsSource="{Binding RemoteFiles}"
                                  SelectionMode="Extended"
                                  MouseDoubleClick="RemoteList_DoubleClick"
                                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <EventSetter Event="PreviewMouseRightButtonDown"
                                                 Handler="ListViewItem_PreviewMouseRightButtonDown"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                                    <GridViewColumn Width="44">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image Width="20" Height="20"
                                                       Source="{Binding ShellIcon}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="名前" Width="220"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="サイズ" Width="80"
                                                    DisplayMemberBinding="{Binding SizeFormatted}"/>
                                    <GridViewColumn Header="更新日時" Width="130"
                                                    DisplayMemberBinding="{Binding ModifiedFormatted}"/>
                                    <GridViewColumn Header="パーミッション" Width="100"
                                                    DisplayMemberBinding="{Binding Permissions}"/>
                                </GridView>
                            </ListView.View>
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="⬇ ダウンロード" Click="RemoteDownload_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📁 フォルダを作成" Click="RemoteNewFolder_Click"/>
                                    <MenuItem Header="📄 ファイルを作成" Click="RemoteNewFile_Click"/>
                                    <Separator/>
                                    <MenuItem Header="🗑 削除" Click="RemoteDelete_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                        </ListView>

                        <!-- Remote status -->
                        <Border Grid.Row="3" Background="#F5F5F5" Padding="10,4"
                                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                            <DockPanel>
                                <TextBlock x:Name="RemoteStatusText" FontSize="11"
                                           Foreground="#666666" Text="準備完了" DockPanel.Dock="Left"/>
                                <TextBlock Foreground="Red" FontSize="11" TextWrapping="Wrap"
                                           Text="{Binding ErrorMessage}"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Transfer queue -->
                <Border Grid.Row="1" Background="#FAFAFA"
                        BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="10,6">
                            <TextBlock Text="転送キュー" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="完了済みをクリア"
                                    Style="{StaticResource ToolBtn}" FontSize="11"
                                    Click="ClearTransfers_Click"/>
                        </DockPanel>
                        <ListView Grid.Row="1" ItemsSource="{Binding Transfers}"
                                  BorderThickness="0" Background="Transparent"
                                  MaxHeight="150">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DirectionIcon}"
                                                   FontFamily="Segoe UI Emoji" FontSize="14"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Grid.Column="2" Value="{Binding Progress}"
                                                     Maximum="1.0" Height="6" Margin="8,0"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
