<Window x:Class="KsFtp.Dialogs.ConnectionFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="接続設定" Width="420"
        SizeToContent="Height"
        MinHeight="400" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White"
        FontFamily="Segoe UI Variable,Segoe UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="新しい接続"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Name -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="接続名" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Padding="8,6" BorderBrush="#CCCCCC"/>
            </StackPanel>

            <!-- Protocol -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="プロトコル" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <ComboBox x:Name="ProtocolCombo" Padding="8,6" BorderBrush="#CCCCCC"
                          SelectionChanged="Protocol_Changed">
                    <ComboBoxItem Content="FTP" Tag="Ftp"/>
                    <ComboBoxItem Content="FTPS (明示的TLS)" Tag="Ftps"/>
                    <ComboBoxItem Content="SFTP (SSH)" Tag="Sftp"/>
                </ComboBox>
            </StackPanel>

            <!-- Encoding -->
            <StackPanel Margin="0,0,0,12" x:Name="EncodingPanel">
                <TextBlock Text="文字コード (FTP/FTPS のファイル名)" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <ComboBox x:Name="EncodingCombo" Padding="8,6" BorderBrush="#CCCCCC">
                    <ComboBoxItem Content="UTF-8" Tag="utf-8"/>
                    <ComboBoxItem Content="Shift-JIS (日本語サーバー)" Tag="shift_jis"/>
                </ComboBox>
            </StackPanel>

            <!-- Host + Port -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ホスト" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="HostBox" Padding="8,6" BorderBrush="#CCCCCC"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ポート" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="PortBox" Padding="8,6" BorderBrush="#CCCCCC"/>
                </StackPanel>
            </Grid>

            <!-- Username -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="ユーザー名" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Padding="8,6" BorderBrush="#CCCCCC"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="パスワード" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Padding="8,6" BorderBrush="#CCCCCC"/>
            </StackPanel>

            <!-- Initial path -->
            <StackPanel>
                <TextBlock Text="フォルダー名 (ホームディレクトリ配下・空欄でホーム)" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="InitialPathBox" Padding="8,6" BorderBrush="#CCCCCC"
                         Text="" xml:space="preserve"/>
                <TextBlock Text="例: public_html  →  ~/public_html/ に接続" FontSize="11"
                           Foreground="#999" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="キャンセル" Padding="16,8" IsCancel="True"
                    Margin="0,0,10,0" Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E8E8E8"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="保存" Padding="16,8" IsDefault="True"
                    Click="Save_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#0078D4"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#106EBE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
